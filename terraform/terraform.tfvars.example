# Copy to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars — it contains your API key.

aws_region        = "us-east-1"
aws_profile       = "default"
project_name      = "lambda-ai-automation"
environment       = "dev"
anthropic_api_key = "sk-ant-api03-YOUR-KEY-HERE"
anthropic_model   = "claude-sonnet-4-20250514"
max_tokens        = 1024
lambda_memory     = 256
lambda_timeout    = 30
